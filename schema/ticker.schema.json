{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tickers/{TICKER}.json (per-ticker history, v2.0.0)",
  "description": "Full 52w signal history + current position metadata for one ticker.",
  "type": "object",
  "required": ["ticker", "schema_version", "history"],
  "properties": {
    "ticker": {"type": "string"},
    "schema_version": {"type": "string", "const": "2.0.0"},
    "current": {
      "type": "object",
      "properties": {
        "signal": {"type": ["string", "null"], "enum": ["BUY", "SELL", null]},
        "signal_source": {"type": ["string", "null"], "enum": ["primary", "secondary", null]},
        "signal_started_date": {"type": ["string", "null"]},
        "signal_trading_days": {"type": ["integer", "null"], "minimum": 0},
        "position_strength": {
          "type": ["string", "null"],
          "enum": ["Strong", "Moderate", "Close to flipping", null]
        }
      }
    },
    "success_rate": {
      "type": "object",
      "required": ["success_rate", "trade_count"],
      "properties": {
        "success_rate": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
        "trade_count": {"type": "integer", "minimum": 0}
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "close", "signal"],
        "properties": {
          "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
          "close": {"type": ["number", "null"]},
          "volume": {"type": ["integer", "null"]},
          "signal": {"type": ["string", "null"], "enum": ["BUY", "SELL", null]},
          "psar": {"type": ["number", "null"]}
        }
      }
    }
  }
}
