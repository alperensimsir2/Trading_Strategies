{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "signals.json (home-screen payload, v2.0.0)",
  "description": "Daily per-ticker signal + metadata. Replaces the 8-state consensus model with BUY/SELL/null from the 15/4 pivot + PSAR strategy.",
  "type": "object",
  "required": ["schema_version", "generated_at", "signals"],
  "properties": {
    "schema_version": {"type": "string", "const": "2.0.0"},
    "generated_at": {"type": "string", "format": "date-time"},
    "trade_date": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "universe_size": {"type": "integer", "minimum": 0},
    "strategy_success_rate_52w": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
    "strategy_trade_count_52w": {"type": "integer", "minimum": 0},
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ticker", "close", "change_pct", "signal"],
        "properties": {
          "ticker": {"type": "string"},
          "close": {"type": ["number", "null"]},
          "change_pct": {"type": ["number", "null"]},
          "signal": {"type": ["string", "null"], "enum": ["BUY", "SELL", null]},
          "signal_source": {"type": ["string", "null"], "enum": ["primary", "secondary", null]},
          "signal_started_date": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
          "signal_trading_days": {"type": ["integer", "null"], "minimum": 0},
          "position_strength": {
            "type": ["string", "null"],
            "enum": ["Strong", "Moderate", "Close to flipping", null]
          },
          "ticker_success_rate_52w": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
          "ticker_trade_count_52w": {"type": "integer", "minimum": 0}
        }
      }
    }
  }
}
